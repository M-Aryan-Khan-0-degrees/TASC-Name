# Copy this file to .streamlit/secrets.toml for LOCAL testing only.
# Never commit secrets.toml — it's already in .gitignore.
# On Streamlit Community Cloud, you'll paste these into the app's
# "Secrets" settings in the dashboard instead of using this file.

ANTHROPIC_API_KEY = "sk-ant-your-key-here"

# Optional: uncomment to require a password before anyone can use the app
# APP_PASSWORD = "choose-something-only-your-team-knows"
